# ArcReel Generator Environment Configuration
# Copy this file to .env and fill in your values
#
# 大部分配置（API Key、後端選擇、速率限制、模型選擇等）
# 已遷移至 WebUI 配置頁（/settings），首次啟動後透過頁面配置即可。
# 此檔案僅保留啟動級/基礎設施配置。

# ============================================================
# 認證配置 (Authentication)
# ============================================================
# 登入使用者名稱（預設: admin）
AUTH_USERNAME=admin
# 登入密碼（留空則首次啟動時自動生成並回寫到此檔案）
AUTH_PASSWORD=
# JWT 簽名金鑰（留空則自動生成，但重啟後 token 失效需重新登入）
AUTH_TOKEN_SECRET=

# ============================================================
# 資料庫配置 (Database Configuration)
# ============================================================
# 預設使用 SQLite（開發/單機）
# SQLite:     sqlite+aiosqlite:///./projects/.arcreel.db
# PostgreSQL: postgresql+asyncpg://user:pass@host:5432/arcreel
# DATABASE_URL=sqlite+aiosqlite:///./projects/.arcreel.db

# ---- Docker Compose 部署專用 ----
# docker-compose.yml 中 postgres 容器使用的密碼，必填。
# arcreel 容器會自動拼成 DATABASE_URL=postgresql+asyncpg://arcreel:${POSTGRES_PASSWORD}@postgres:5432/arcreel
# 直接執行（非 docker）時無需設定。
POSTGRES_PASSWORD=

# arcreel 應用程式埠（預設 1241）。docker compose 會同時用於主機映射與容器內 uvicorn。
PORT=1241

# ============================================================
# 日誌配置 (Logging)
# ============================================================
# 日誌級別（預設: INFO，可選: DEBUG, WARNING, ERROR）
# LOG_LEVEL=INFO

# ============================================================
# 助手執行時供應商 (Assistant Runtime Provider)
# ============================================================
# 控制 /api/v1/.../assistant 與 /agent_chat 走哪條 LLM 路徑
#   gemini_lite   — 對話模式：純文字交流，無工具呼叫（預設）
#   gemini_full   — 工作流模式：Gemini function calling，可呼叫 fs_*/skill 工具自動化
#                   生成劇本、分鏡、角色等。需要 AI Studio API key 並在 /settings 配置
#   openai_lite   — 對話模式：走 OpenAI 文字後端
#   claude        — Claude Agent SDK 工作流模式（會繫結 bundled CLI 與登入態，不推薦）
# ASSISTANT_PROVIDER=gemini_lite

# ============================================================
# 影片供應商 (Video Provider)
# ============================================================
# DEFAULT_VIDEO_PROVIDER=gemini     # 全域性預設影片供應商 (gemini | seedance)

# ============================================================
# Seedance (火山方舟) 配置
# ============================================================
# ARK_API_KEY=                      # 火山方舟 API key
# FILE_SERVICE_BASE_URL=            # 專案檔案服務公網地址 (Seedance 圖片上傳需要公網訪問)
