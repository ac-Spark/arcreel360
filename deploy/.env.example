# ArcReel 預設部署環境配置（SQLite）
# 複製為 .env 後填入你的值

# ============================================================
# 認證配置 (Authentication)
# ============================================================
# 登入使用者名稱（預設: admin）
AUTH_USERNAME=admin
# 登入密碼（留空則首次啟動時自動生成並回寫到 .env 檔案）
AUTH_PASSWORD=
# JWT 簽名金鑰（留空則自動生成，但重啟後 token 失效需重新登入）
AUTH_TOKEN_SECRET=

# ============================================================
# 日誌配置 (Logging)
# ============================================================
# 日誌級別（預設: INFO，可選: DEBUG, WARNING, ERROR）
# LOG_LEVEL=INFO
